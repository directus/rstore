{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "types": [
      "node",
      "vite/client"
    ],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    ".vitepress/**/*.ts",
    ".vitepress/**/*.mts",
    "**/*.ts",
    "**/*.mts",
    "**/*.vue"
  ],
  "exclude": [
    ".vitepress/cache",
    ".vitepress/dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "node_modules"
  ]
}
