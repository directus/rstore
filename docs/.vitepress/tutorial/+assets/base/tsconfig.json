{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "@vue/typescript-plugin"
      }
    ],
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src/**/*"
  ]
}
